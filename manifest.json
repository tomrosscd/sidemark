{
  "manifest_version": 3,
  "name": "Sidemark",
  "version": "2.0.0",
  "description": "Shopify Sidekick chat, exported clean into Markdown — plus a built-in prompt library.",
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Sidemark",
    "default_icon": {
      "16": "icons/sidekick16.png",
      "48": "icons/sidekick48.png",
      "128": "icons/sidekick128.png"
    }
  },
  "icons": {
    "16": "icons/sidekick16.png",
    "48": "icons/sidekick48.png",
    "128": "icons/sidekick128.png"
  },
  "permissions": ["activeTab", "scripting", "clipboardWrite", "sidePanel", "storage"],
  "host_permissions": [
    "https://admin.shopify.com/*",
    "https://*.myshopify.com/*"
  ]
}

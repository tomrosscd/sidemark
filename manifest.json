{
  "manifest_version": 3,
  "name": "Sidemark",
  "version": "1.0.0",
  "description": "Shopify Sidekick chat, exported clean into Markdown.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/sidekick16.png",
      "48": "icons/sidekick48.png",
      "128": "icons/sidekick128.png"
    }
  },
  "icons": {
    "16": "icons/sidekick16.png",
    "48": "icons/sidekick48.png",
    "128": "icons/sidekick128.png"
  },
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://admin.shopify.com/*",
    "https://*.myshopify.com/*"
  ]
}
